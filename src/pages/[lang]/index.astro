      IR:'🇮🇷',IQ:'🇮🇶',SY:'🇸🇾',LB:'🇱🇧',QA:'🇶🇦',KW:'🇰🇼',BH:'🇧🇭',OM:'🇴🇲',JO:'🇯🇴',
