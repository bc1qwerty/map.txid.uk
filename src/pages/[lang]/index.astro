---
import Base from '../../layouts/Base.astro';
import Header from '@txid/ui/components/Header.astro';
import Footer from '@txid/ui/components/Footer.astro';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;

const titles: Record<string, string> = {
  ko: 'Bitcoin Lightning л…ёл“ң & мұ„көҙ н’Җ м„ёкі„ м§ҖлҸ„ | txid.uk',
  en: 'Bitcoin Lightning Node & Mining Pool World Map | txid.uk',
  ja: 'Bitcoin Lightning гғҺгғјгғү & гғһгӮӨгғӢгғігӮ°гғ—гғјгғ« дё–з•Ңең°еӣі | txid.uk',
};

const descriptions: Record<string, string> = {
  ko: 'л№„нҠёмҪ”мқё лқјмқҙнҠёлӢқ л…ёл“ң л°Ҹ мұ„көҙ н’Җмқҳ көӯк°Җлі„ л¶„нҸ¬лҘј м„ёкі„ м§ҖлҸ„ мң„м—җ мӢңк°Ғнҷ”.',
  en: 'Visualize global distribution of Bitcoin Lightning nodes and mining pools on a world map.',
  ja: 'гғ“гғғгғҲгӮігӮӨгғі гғ©гӮӨгғҲгғӢгғігӮ°гғҺгғјгғүгҒЁгғһгӮӨгғӢгғігӮ°гғ—гғјгғ«гҒ®еӣҪеҲҘеҲҶеёғгӮ’дё–з•Ңең°еӣідёҠгҒ§еҸҜиҰ–еҢ–гҖӮ',
};

const i18n: Record<string, Record<string, string>> = {
  learnMore: { ko: 'лҚ” м•Ңм•„ліҙкё°', en: 'Learn more', ja: 'гӮӮгҒЈгҒЁеӯҰгҒ¶' },
  miningChip: { ko: 'л№„нҠёмҪ”мқё мұ„көҙ', en: 'Bitcoin Mining', ja: 'гғһгӮӨгғӢгғігӮ°' },
  lnChip: { ko: 'лқјмқҙнҠёлӢқ л„ӨнҠёмӣҢнҒ¬ мһ…л¬ё', en: 'Lightning Network Intro', ja: 'гғ©гӮӨгғҲгғӢгғігӮ°е…Ҙй–Җ' },
  tabLightning: { ko: 'лқјмқҙнҠёлӢқ', en: 'Lightning', ja: 'гғ©гӮӨгғҲгғӢгғігӮ°' },
  tabMining: { ko: 'мұ„көҙ н’Җ', en: 'Mining', ja: 'гғһгӮӨгғӢгғігӮ°' },
};

const tx = (key: string) => i18n[key]?.[lang!] || i18n[key]?.en || key;
const learnLangPrefix = lang === 'en' ? 'en' : lang === 'ja' ? 'ja' : 'ko';
const mapAriaLabel = lang === 'en' ? 'World map of Bitcoin nodes and mining pool distribution by country' : lang === 'ja' ? 'гғ“гғғгғҲгӮігӮӨгғігғҺгғјгғүгҒЁгғһгӮӨгғӢгғігӮ°гғ—гғјгғ«гҒ®еӣҪеҲҘеҲҶеёғдё–з•Ңең°еӣі' : 'л№„нҠёмҪ”мқё л…ёл“ң л°Ҹ мұ„көҙн’Җ көӯк°Җлі„ л¶„нҸ¬ м„ёкі„ м§ҖлҸ„';
---

<Base
  title={titles[lang!] || titles.en}
  description={descriptions[lang!] || descriptions.en}
  lang={lang!}
>
  <Header sub="Map" />

  <div class="learn-links" id="learn-links">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-noshrink" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    <span class="learn-label">{tx('learnMore')}</span>
    <a class="learn-chip" data-slug="bitcoin-mining" href={`https://learn.txid.uk/${learnLangPrefix}/blog/bitcoin-mining/`} target="_blank" rel="noopener">{tx('miningChip')}</a>
    <a class="learn-chip" data-slug="lightning-network-intro" href={`https://learn.txid.uk/${learnLangPrefix}/blog/lightning-network-intro/`} target="_blank" rel="noopener">{tx('lnChip')}</a>
  </div>

  <main id="main">
    <h1 class="sr-only">{titles[lang!] || titles.en}</h1>
    <div class="map-wrap">
      <div class="map-tab-overlay">
        <button class="tab-btn active" id="tab-ln"><svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> <span>{tx('tabLightning')}</span></button>
        <button class="tab-btn" id="tab-mining"><svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><path d="M15 4l5 5-11 11H4v-5L15 4z"/><line x1="9" y1="9" x2="15" y2="15"/></svg> <span>{tx('tabMining')}</span></button>
      </div>
      <svg id="world-map" viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid meet" role="img" aria-label={mapAriaLabel}></svg>
      <div id="map-tooltip" class="map-tooltip hidden"></div>
    </div>

    <div class="stats-panel">
      <div id="global-stats" class="global-stats" aria-live="polite"></div>
      <div id="country-list" class="country-list" aria-live="polite"></div>
    </div>
  </main>

  <Footer />

  <script define:vars={{ pageLang: lang }}>
    window.__pageLang = pageLang;
  </script>

  <script>
    function escHtml(s: string | number | null | undefined): string {
      return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    async function fetchRetry(url: string, timeout?: number, retries?: number): Promise<Response> {
      for (let i = 0, m = retries || 2; i <= m; i++) {
        try {
          return await fetch(url, { signal: AbortSignal.timeout(timeout || 10000) });
        } catch (e) {
          if (i >= m) throw e;
          await new Promise(r => setTimeout(r, 1000 << i));
        }
      }
      throw new Error('fetchRetry exhausted');
    }

    // Declare global d3 and topojson loaded via CDN
    declare const d3: any;
    declare const topojson: any;

    // в”Җв”Җ i18n в”Җв”Җ
    const pageLang = (window as any).__pageLang || 'ko';
    let lang = localStorage.getItem('lang') || pageLang;
    const LABELS: Record<string, Record<string, string>> = {
      ko: {нғҗмғүкё°:'нғҗмғүкё°', лҸ„кө¬:'лҸ„кө¬', мӢңк°Ғнҷ”:'мӢңк°Ғнҷ”', нҶөкі„:'нҶөкі„', л…ёл“ң:'л…ёл“ң', м§ҖлҸ„:'м§ҖлҸ„', нҸ¬нҠёнҸҙлҰ¬мҳӨ:'нҸ¬нҠёнҸҙлҰ¬мҳӨ', м „мҶЎ:'м „мҶЎ', л°°мҡ°кё°:'л°°мҡ°кё°', м•ұлӘЁмқҢ:'м•ұлӘЁмқҢ'},
      en: {нғҗмғүкё°:'Explorer', лҸ„кө¬:'Tools', мӢңк°Ғнҷ”:'Viz', нҶөкі„:'Stats', л…ёл“ң:'Nodes', м§ҖлҸ„:'Map', нҸ¬нҠёнҸҙлҰ¬мҳӨ:'Portfolio', м „мҶЎ:'TX', л°°мҡ°кё°:'Learn', м•ұлӘЁмқҢ:'Apps'},
      ja: {нғҗмғүкё°:'жҺўзҙў', лҸ„кө¬:'гғ„гғјгғ«', мӢңк°Ғнҷ”:'еҸҜиҰ–еҢ–', нҶөкі„:'зөұиЁҲ', л…ёл“ң:'гғҺгғјгғү', м§ҖлҸ„:'ең°еӣі', нҸ¬нҠёнҸҙлҰ¬мҳӨ:'иіҮз”Ј', м „мҶЎ:'йҖҒйҮ‘', л°°мҡ°кё°:'еӯҰзҝ’', м•ұлӘЁмқҢ:'гӮўгғ—гғӘ'},
    };

    const i18n: Record<string, Record<string, string>> = {
      ko: {
        loading: 'лЎңл”© мӨ‘вҖҰ',
        total_nodes: 'мҙқ л…ёл“ң мҲҳ', channels: 'мұ„л„җ мҲҳ', capacity: 'мҙқ мҡ©лҹү',
        active_pools: 'нҷңм„ұ л§ҲмқҙлӢқ н’Җ', blocks_7d: 'мөңк·ј 7мқј лё”лЎқ',
        node_label: 'л…ёл“ң', block_label: 'лё”лЎқ',
        load_fail: 'лҚ°мқҙн„° лЎңл“ң мӢӨнҢЁ',
      },
      en: {
        loading: 'LoadingвҖҰ',
        total_nodes: 'Total Nodes', channels: 'Channels', capacity: 'Capacity',
        active_pools: 'Active Pools', blocks_7d: '7-day Blocks',
        node_label: 'nodes', block_label: 'blocks',
        load_fail: 'Failed to load data',
      },
      ja: {
        loading: 'иӘӯгҒҝиҫјгҒҝдёӯвҖҰ',
        total_nodes: 'з·ҸгғҺгғјгғүж•°', channels: 'гғҒгғЈгғігғҚгғ«ж•°', capacity: 'з·Ҹе®№йҮҸ',
        active_pools: 'гӮўгӮҜгғҶгӮЈгғ–гғ—гғјгғ«', blocks_7d: '7ж—Ҙй–“гғ–гғӯгғғгӮҜ',
        node_label: 'гғҺгғјгғү', block_label: 'гғ–гғӯгғғгӮҜ',
        load_fail: 'гғҮгғјгӮҝеҸ–еҫ—еӨұж•—',
      },
    };

    function t(k: string): string { return (i18n[lang] && i18n[lang][k]) || i18n.ko[k] || k; }

    function setLang(l: string) {
      lang = l; localStorage.setItem('lang', lang);
      const target = '/' + lang + '/';
      if (window.location.pathname !== target) {
        window.location.href = target;
        return;
      }
      document.documentElement.lang = lang;
      const btn = document.getElementById('lang-btn');
      if (btn) btn.textContent = ({ ko: 'KO', en: 'EN', ja: 'JA' } as Record<string, string>)[lang] || 'KO';
      document.getElementById('lang-menu')?.classList.remove('open');
      document.querySelectorAll<HTMLElement>('[data-ko]').forEach(el => {
        const val = el.dataset[lang] || el.dataset.en || el.dataset.ko;
        if (val) {
          if ('placeholder' in el && (el as HTMLInputElement).placeholder !== undefined) (el as HTMLInputElement).placeholder = val;
          else el.textContent = val;
        }
      });
      if ((window as any)._mapData) loadData();
    }

    function toggleLang() {
      const m = document.getElementById('lang-menu');
      m?.classList.toggle('open');
      document.getElementById('lang-btn')?.setAttribute('aria-expanded', String(m?.classList.contains('open') || false));
    }

    document.addEventListener('click', e => {
      const m = document.getElementById('lang-menu');
      if (m && !(e.target as HTMLElement).closest('.lang-dropdown')) {
        m.classList.remove('open');
        document.getElementById('lang-btn')?.setAttribute('aria-expanded', 'false');
      }
    });

    // If stored lang differs from page lang, navigate
    if (lang !== pageLang && ['ko', 'en', 'ja'].includes(lang)) {
      window.location.href = '/' + lang + '/';
    }

    (function () { setLang(lang); })();

    const API = 'https://mempool.space/api';
    let currentTab = 'ln';

    // в”Җв”Җ Theme в”Җв”Җ
    const sunSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/></svg>';
    const moonSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
    const sunSvgSm = sunSvg.replace(/width="15" height="15"/g, 'width="14" height="14"');
    const moonSvgSm = moonSvg.replace(/width="15" height="15"/g, 'width="14" height="14"');

    (function () {
      const th = localStorage.getItem('theme') || 'dark';
      const isDark = th !== 'light';
      document.documentElement.setAttribute('data-theme', th);
      const btn = document.getElementById('theme-btn');
      if (btn) {
        btn.innerHTML = isDark ? sunSvg : moonSvg;
        btn.title = isDark ? 'лқјмқҙнҠё лӘЁл“ңлЎң м „нҷҳ' : 'лӢӨнҒ¬ лӘЁл“ңлЎң м „нҷҳ';
      }
    })();

    function updateThemeBtn() {
      const btn = document.getElementById('theme-btn');
      if (!btn) return;
      const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
      btn.innerHTML = isDark ? sunSvg : moonSvg;
      btn.title = isDark ? 'лқјмқҙнҠё лӘЁл“ңлЎң м „нҷҳ' : 'лӢӨнҒ¬ лӘЁл“ңлЎң м „нҷҳ';
    }

    function toggleTheme() {
      const h = document.documentElement;
      const next = h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      h.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateThemeBtn();
      renderMap((window as any)._mapData);
    }

    function switchTab(tab: string) {
      currentTab = tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('tab-' + tab)?.classList.add('active');
      loadData();
    }

    const FLAGS: Record<string, string> = {
      US:'рҹҮәрҹҮё',DE:'рҹҮ©рҹҮӘ',GB:'рҹҮ¬рҹҮ§',FR:'рҹҮ«рҹҮ·',NL:'рҹҮірҹҮұ',CA:'рҹҮЁрҹҮҰ',SG:'рҹҮёрҹҮ¬',JP:'рҹҮҜрҹҮө',AU:'рҹҮҰрҹҮә',CH:'рҹҮЁрҹҮӯ',
      FI:'рҹҮ«рҹҮ®',SE:'рҹҮёрҹҮӘ',NO:'рҹҮірҹҮҙ',BR:'рҹҮ§рҹҮ·',KR:'рҹҮ°рҹҮ·',IN:'рҹҮ®рҹҮі',RU:'рҹҮ·рҹҮә',IT:'рҹҮ®рҹҮ№',ES:'рҹҮӘрҹҮё',PL:'рҹҮөрҹҮұ',
      AT:'рҹҮҰрҹҮ№',CZ:'рҹҮЁрҹҮҝ',UA:'рҹҮәрҹҮҰ',TR:'рҹҮ№рҹҮ·',AR:'рҹҮҰрҹҮ·',MX:'рҹҮІрҹҮҪ',ZA:'рҹҮҝрҹҮҰ',TH:'рҹҮ№рҹҮӯ',ID:'рҹҮ®рҹҮ©',TW:'рҹҮ№рҹҮј',
      HK:'рҹҮӯрҹҮ°',CN:'рҹҮЁрҹҮі',MY:'рҹҮІрҹҮҫ',PH:'рҹҮөрҹҮӯ',VN:'рҹҮ»рҹҮі',RO:'рҹҮ·рҹҮҙ',HU:'рҹҮӯрҹҮә',SK:'рҹҮёрҹҮ°',DK:'рҹҮ©рҹҮ°',BE:'рҹҮ§рҹҮӘ',
      PT:'рҹҮөрҹҮ№',GR:'рҹҮ¬рҹҮ·',BG:'рҹҮ§рҹҮ¬',HR:'рҹҮӯрҹҮ·',LT:'рҹҮұрҹҮ№',LV:'рҹҮұрҹҮ»',EE:'рҹҮӘрҹҮӘ',IL:'рҹҮ®рҹҮұ',AE:'рҹҮҰрҹҮӘ',SA:'рҹҮёрҹҮҰ',
      IS:'рҹҮ®рҹҮё',IE:'рҹҮ®рҹҮӘ',LU:'рҹҮұрҹҮә',SI:'рҹҮёрҹҮ®',CL:'рҹҮЁрҹҮұ',CO:'рҹҮЁрҹҮҙ',NZ:'рҹҮірҹҮҝ',UY:'рҹҮәрҹҮҫ',PY:'рҹҮөрҹҮҫ',
      PE:'рҹҮөрҹҮӘ',VE:'рҹҮ»рҹҮӘ',BO:'рҹҮ§рҹҮҙ',NG:'рҹҮірҹҮ¬',KE:'рҹҮ°рҹҮӘ',GH:'рҹҮ¬рҹҮӯ',MA:'рҹҮІрҹҮҰ',EG:'рҹҮӘрҹҮ¬',TN:'рҹҮ№рҹҮі',
      IR:'рҹҮ®рҹҮ·',IQ:'рҹҮ®рҹҮ¶',SY:'рҹҮёрҹҮҫ',LB:'рҹҮұрҹҮ§',QA:'рҹҮ¶рҹҮҰ',KW:'рҹҮ°рҹҮј',BH:'рҹҮ§рҹҮӯ',OM:'рҹҮҙрҹҮІ',JO:'рҹҮҜрҹҮҙ',
      PK:'рҹҮөрҹҮ°',BD:'рҹҮ§рҹҮ©',LK:'рҹҮұрҹҮ°',NP:'рҹҮірҹҮө',MM:'рҹҮІрҹҮІ',KH:'рҹҮ°рҹҮӯ',
      BY:'рҹҮ§рҹҮҫ',MD:'рҹҮІрҹҮ©',AM:'рҹҮҰрҹҮІ',GE:'рҹҮ¬рҹҮӘ',AZ:'рҹҮҰрҹҮҝ',KZ:'рҹҮ°рҹҮҝ',KG:'рҹҮ°рҹҮ¬',UZ:'рҹҮәрҹҮҝ',
      AL:'рҹҮҰрҹҮұ',RS:'рҹҮ·рҹҮё',BA:'рҹҮ§рҹҮҰ',ME:'рҹҮІрҹҮӘ',MK:'рҹҮІрҹҮ°',MT:'рҹҮІрҹҮ№',CY:'рҹҮЁрҹҮҫ',LI:'рҹҮұрҹҮ®',AD:'рҹҮҰрҹҮ©',
      CU:'рҹҮЁрҹҮә',DO:'рҹҮ©рҹҮҙ',CR:'рҹҮЁрҹҮ·',PA:'рҹҮөрҹҮҰ',SV:'рҹҮёрҹҮ»',GT:'рҹҮ¬рҹҮ№',HN:'рҹҮӯрҹҮі',NI:'рҹҮірҹҮ®',BZ:'рҹҮ§рҹҮҝ',
      PR:'рҹҮөрҹҮ·',JM:'рҹҮҜрҹҮІ',BS:'рҹҮ§рҹҮё',BM:'рҹҮ§рҹҮІ',VG:'рҹҮ»рҹҮ¬',AI:'рҹҮҰрҹҮ®',CW:'рҹҮЁрҹҮј',
      AO:'рҹҮҰрҹҮҙ',ZM:'рҹҮҝрҹҮІ',ZW:'рҹҮҝрҹҮј',MZ:'рҹҮІрҹҮҝ',TZ:'рҹҮ№рҹҮҝ',ET:'рҹҮӘрҹҮ№',
      VA:'рҹҮ»рҹҮҰ',SM:'рҹҮёрҹҮІ',MC:'рҹҮІрҹҮЁ',FO:'рҹҮ«рҹҮҙ',
    };

    const NAMES: Record<string, string> = {
      US:'лҜёкөӯ',DE:'лҸ…мқј',GB:'мҳҒкөӯ',FR:'н”„лһ‘мҠӨ',NL:'л„ӨлҚңлһҖл“ң',CA:'мәҗлӮҳлӢӨ',SG:'мӢұк°ҖнҸ¬лҘҙ',JP:'мқјліё',
      AU:'нҳёмЈј',CH:'мҠӨмң„мҠӨ',FI:'н•ҖлһҖл“ң',SE:'мҠӨмӣЁлҚҙ',NO:'л…ёлҘҙмӣЁмқҙ',BR:'лёҢлқјм§Ҳ',KR:'н•ңкөӯ',IN:'мқёлҸ„',
