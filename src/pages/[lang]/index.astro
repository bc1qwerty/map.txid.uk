---
import Base from '../../layouts/Base.astro';
import Header from '@txid/ui/components/Header.astro';
import Footer from '@txid/ui/components/Footer.astro';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ko' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;

const titles: Record<string, string> = {
  ko: '비트코인 네트워크 지도 — 노드 & 채굴 인프라 탐색 | map.txid.uk',
  en: 'Bitcoin Network Map — Node & Mining Infrastructure Explorer | map.txid.uk',
  ja: 'ビットコイン ネットワーク地図 — ノード & マイニング探索 | map.txid.uk',
};

const descriptions: Record<string, string> = {
  ko: '비트코인 네트워크 지도. 전 세계 비트코인 노드와 채굴 인프라를 시각적으로 탐색하세요.',
  en: 'Bitcoin network map. Visually explore Bitcoin nodes and mining infrastructure around the world.',
  ja: 'ビットコインネットワーク地図。世界中のビットコインノードとマイニングインフラを視覚的に探索。',
};

const i18n: Record<string, Record<string, string>> = {
  learnMore: { ko: '더 알아보기', en: 'Learn more', ja: 'もっと学ぶ' },
  miningChip: { ko: '비트코인 채굴', en: 'Bitcoin Mining', ja: 'マイニング' },
  lnChip: { ko: '라이트닝 네트워크 입문', en: 'Lightning Network Intro', ja: 'ライトニング入門' },
  tabLightning: { ko: '라이트닝', en: 'Lightning', ja: 'ライトニング' },
  tabMining: { ko: '채굴 풀', en: 'Mining', ja: 'マイニング' },
};

const tx = (key: string) => i18n[key]?.[lang!] || i18n[key]?.en || key;
const learnLangPrefix = lang === 'en' ? 'en' : lang === 'ja' ? 'ja' : 'ko';
const mapAriaLabel = lang === 'en' ? 'World map of Bitcoin nodes and mining pool distribution by country' : lang === 'ja' ? 'ビットコインノードとマイニングプールの国別分布世界地図' : '비트코인 노드 및 채굴풀 국가별 분포 세계 지도';
---

<Base
  title={titles[lang!] || titles.en}
  description={descriptions[lang!] || descriptions.en}
  lang={lang!}
>
  <Header sub="Map & Nodes" />

  <div class="learn-links" id="learn-links">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-noshrink" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    <span class="learn-label">{tx('learnMore')}</span>
    <a class="learn-chip" data-slug="bitcoin-mining" href={`https://learn.txid.uk/${learnLangPrefix}/blog/bitcoin-mining/`} target="_blank" rel="noopener">{tx('miningChip')}</a>
    <a class="learn-chip" data-slug="lightning-network-intro" href={`https://learn.txid.uk/${learnLangPrefix}/blog/lightning-network-intro/`} target="_blank" rel="noopener">{tx('lnChip')}</a>
  </div>

  <main id="main" class="map-dashboard">
    <h1 class="sr-only">{titles[lang!] || titles.en}</h1>

    <!-- LEFT: Node Explorer -->
    <nav class="map-left-col">
      <!-- Network History -->
      <div class="sidebar-section ln-only" id="network-history-section">
        <h3 class="section-title" data-ko="네트워크 추이" data-en="Network History" data-ja="ネットワーク推移">Network History</h3>
        <div id="network-chart"></div>
      </div>

      <!-- Node Search -->
      <div class="sidebar-section ln-only" id="node-search-section">
        <h3 class="section-title" data-ko="노드 검색" data-en="Node Search" data-ja="ノード検索">Node Search</h3>
        <div class="node-search-row">
          <input type="text" id="node-search-input" class="search-input" data-ko="노드 별칭 또는 pubkey..." data-en="Node alias or pubkey..." data-ja="ノードエイリアスまたはpubkey..." placeholder="Node alias or pubkey..." />
          <button id="node-search-btn" class="search-btn" data-ko="검색" data-en="Search" data-ja="검색">Search</button>
        </div>
        <div id="node-search-results"></div>
      </div>

      <!-- Top Nodes -->
      <div class="sidebar-section ln-only" id="top-nodes-section">
        <h3 class="section-title" data-ko="상위 노드" data-en="Top Nodes" data-ja="トップノード">Top Nodes</h3>
        <div id="top-nodes" class="node-list"></div>
      </div>

      <!-- Node Detail -->
      <div id="node-detail" class="node-detail hidden"></div>
    </nav>

    <!-- CENTER: 3D Globe (Quad Viewport) -->
    <div class="map-globe-col">
      <div class="map-wrap">
        <!-- Quad grid overlay (desktop only) -->
        <div class="quad-grid" id="quad-grid">
          <div class="quad-cell" data-quad="ln">
            <div class="quad-header">
              <span class="quad-icon">&#9889;</span>
              <span class="quad-label" data-ko="라이트닝" data-en="Lightning" data-ja="ライトニング">Lightning</span>
              <span class="quad-stat" id="quad-stat-ln"></span>
            </div>
            <div class="quad-mini-list" id="quad-list-ln"></div>
          </div>
          <div class="quad-cell" data-quad="mining">
            <div class="quad-header">
              <span class="quad-icon">&#9935;</span>
              <span class="quad-label" data-ko="마이닝" data-en="Mining" data-ja="マイニング">Mining</span>
              <span class="quad-stat" id="quad-stat-mining"></span>
            </div>
            <div class="quad-mini-list" id="quad-list-mining"></div>
          </div>
          <div class="quad-cell" data-quad="fullnode">
            <div class="quad-header">
              <span class="quad-icon">&#128423;</span>
              <span class="quad-label" data-ko="풀 노드" data-en="Full Nodes" data-ja="フルノード">Full Nodes</span>
              <span class="quad-stat" id="quad-stat-fullnode"></span>
            </div>
            <div class="quad-mini-list" id="quad-list-fullnode"></div>
          </div>
          <div class="quad-cell" data-quad="isp">
            <div class="quad-header">
              <span class="quad-icon">&#127760;</span>
              <span class="quad-label" data-ko="ISP" data-en="ISP" data-ja="ISP">ISP</span>
              <span class="quad-stat" id="quad-stat-isp"></span>
            </div>
            <div class="quad-mini-list" id="quad-list-isp"></div>
          </div>
        </div>
        <!-- Mobile tab overlay (shown on mobile only) -->
        <div class="map-tab-overlay mobile-only" id="mobile-tab-overlay">
          <button class="tab-btn active" id="tab-ln"><svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> <span>{tx('tabLightning')}</span></button>
          <button class="tab-btn" id="tab-mining"><svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><path d="M15 4l5 5-11 11H4v-5L15 4z"/><line x1="9" y1="9" x2="15" y2="15"/></svg> <span>{tx('tabMining')}</span></button>
        </div>
        <canvas id="globe-canvas" role="img" aria-label={mapAriaLabel}></canvas>
        <div id="map-tooltip" class="map-tooltip hidden"></div>
      </div>
    </div>

    <!-- RIGHT: Country List -->
    <aside class="map-data-col">
      <!-- Mining stats (Mining tab only) -->
      <div id="global-stats" class="global-stats" aria-live="polite"></div>
      <div id="country-list" class="country-list" aria-live="polite"></div>
    </aside>
  </main>

  <Footer />

  <script define:vars={{ pageLang: lang }}>
    window.__pageLang = pageLang;
  </script>

  <!-- Three.js + topojson bundled from npm (tree-shaken by Astro/Vite) -->
  <script src="../../scripts/three-setup.ts"></script>

  <script src="/js/map-data.js" is:inline></script>
  <script src="/js/map-i18n.js" is:inline></script>
  <script src="/js/map-engine.js" is:inline></script>
  <script src="/js/node-explorer.js" is:inline></script>
</Base>
